{
  "name": "@agentrelationsprotocol/arp-verify",
  "version": "0.2.1",
  "description": "CLI to verify Agent Relations Protocol (ARP) endpoint compliance. Fetches DID documents, agent cards, the discovery index, and tests signed messaging, first-contact enforcement, and signature validation.",
  "keywords": [
    "arp",
    "agent",
    "agents",
    "agent-protocol",
    "agent-relations-protocol",
    "did",
    "ed25519",
    "verification",
    "cli",
    "conformance"
  ],
  "license": "Apache-2.0",
  "author": "Tiago Pita",
  "homepage": "https://agentrelationsprotocol.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clerkboard/arp-verify.git"
  },
  "bugs": {
    "url": "https://github.com/Clerkboard/arp/issues"
  },
  "type": "module",
  "bin": {
    "arp-verify": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
